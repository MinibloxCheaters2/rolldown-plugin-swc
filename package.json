{
  "name": "@wq2/rolldown-plugin-swc",
  "version": "0.0.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Transpile JavaScript/TypeScript code with swc.",
  "license": "MIT",
  "repository": {
    
  },
  "type": "module",
  "author": "Peter Placzek <peter.placzek1996@gmail.com>",
  "homepage": "https://github.com/rollup/plugins/tree/master/packages/swc#readme",
  "bugs": "https://github.com/rollup/plugins/issues",
  "main": "dist/cjs/index.js",
  "module": "dist/es/index.js",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/es/index.js",
    "default": "./dist/cjs/index.js"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "build": "tsdown"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "src",
    "types",
    "README.md"
  ],
  "keywords": [
    "rollup",
    "plugin",
    "swc",
    "speedy-web-compiler",
    "npm",
    "modules"
  ],
  "peerDependencies": {
    "@swc/core": "^1.3.0",
    "rolldown": "^1.0.0-rc.6"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "smob": "^1.6.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5.9.3"
  },
  "types": "./types/index.d.ts"
}
